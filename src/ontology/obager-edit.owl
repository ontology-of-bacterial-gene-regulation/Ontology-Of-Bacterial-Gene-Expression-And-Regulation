                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>DNA-binding regulatory protein of transcription initiation that binds near a promoter and affect transcript initiation at that promoter with some mechanisms that allows it to be active in some conditions and inactive in other conditions</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32665585</obo:IAO_0000119>
        <rdfs:comment>The fact that these proteins bind near the promoter should be represented in the transcription factor regulatory site class.</rdfs:comment>
        <rdfs:label xml:lang="en">transcription factor</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000034">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000009"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000129"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000001"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000009"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000134"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000185"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>

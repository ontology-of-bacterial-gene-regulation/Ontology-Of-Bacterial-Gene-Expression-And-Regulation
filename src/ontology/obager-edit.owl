        </rdfs:subClassOf>
        <obo:IAO_0000115>A molecular entity whose structure or sequence is specified by genetic information contained in the genome.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">genetically specified biomacromolecular entity</rdfs:label>
    </owl:Class>
    



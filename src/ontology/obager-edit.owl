    <!-- http://purl.obolibrary.org/obo/OBAGER_0000077 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000077">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000038"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000092"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <obo:IAO_0000115>An entity that increases or decreases the activity of a molecule or the expression of a specific set of genes.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000080 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000080">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000077"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000178"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>A regulator that is a biomacromolecule capable of physically interacting with one or more target biomacromolecules, distinct from its origin, to functionally regulate their activity or expression.

A genomically specified regulator that is a molecule that is the product of transcription.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">trans-acting regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000082 -->


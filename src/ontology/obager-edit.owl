            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a trans-acting regulator that binds to an RNA molecule and, by doing so, increases or decreases its degradation rate, thereby modulating its half-life without directly affecting its transcription or translation</obo:IAO_0000115>
        <rdfs:label xml:lang="en">trans-acting regulator of mRNA stability</rdfs:label>
    </owl:Class>
    



    <!-- http://purl.obolibrary.org/obo/OBAGER_0000006 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000006">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <obo:IAO_0000115>a data property that specifies the exact order of bases in a nucleic acid or of amino acids in a protein</obo:IAO_0000115>
        <obo:IAO_0000119>https://www.merriam-webster.com/dictionary/sequence</obo:IAO_0000119>
        <owlready_ontology:python_name>OBAGER_0000006</owlready_ontology:python_name>
        <rdfs:label xml:lang="en">has sequence</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000007 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000007">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <obo:IAO_0000115>indicates the number designating the place occupied by a nucleotide in a DNA molecule in the 5&apos; to 3&apos; direction of the forward strand</obo:IAO_0000115>
        <obo:IAO_0000119>adapted from https://www.merriam-webster.com/dictionary/ordinal%20number</obo:IAO_0000119>
        <terms:contributor>https://orcid.org/0000-0002-0142-5591</terms:contributor>
        <owlready_ontology:python_name>OBAGER_0000007</owlready_ontology:python_name>
        <rdfs:comment>DNA strand serves as the reference axis of coordinates, but this data property can be assigned to an RNA molecule too, in which case the coordinate indicates the DNA segment from which the RNA molecule was produced.</rdfs:comment>
        <rdfs:comment>Note that the coordinate axis is the forward strand, but the same coordinate point to a position in any of the two strands or to a position in the double stranded DNA.</rdfs:comment>
        <rdfs:label xml:lang="en">has coordinate in the DNA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000012 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000012">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000007"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <obo:IAO_0000115>indicates the number designating the place occupied by the firts nucleotide of an object in a DNA molecule in the 5&apos; to 3&apos; direction of the forward strand</obo:IAO_0000115>
        <owlready_ontology:python_name>OBAGER_0000012</owlready_ontology:python_name>
        <rdfs:label xml:lang="en">has left end coordinate in the DNA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000019 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000019">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000007"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <obo:IAO_0000115>indicates the number designating the place occupied by the last nucleotide of an object in a DNA molecule in the 5&apos; to 3&apos; direction of the forward strand</obo:IAO_0000115>
        <owlready_ontology:python_name>OBAGER_0000019</owlready_ontology:python_name>
        <rdfs:label xml:lang="en">has right end coordinate in the DNA</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000036 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000036">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000007"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <obo:IAO_0000115>indicates the number designating the place occupied by the central nucleotide of an object in a DNA molecule in the 5&apos; to 3&apos; direction of the forward strand</obo:IAO_0000115>
        <owlready_ontology:python_name>OBAGER_0000036</owlready_ontology:python_name>
        <rdfs:label xml:lang="en">has absolute center position</rdfs:label>
    </owl:DatatypeProperty>
    



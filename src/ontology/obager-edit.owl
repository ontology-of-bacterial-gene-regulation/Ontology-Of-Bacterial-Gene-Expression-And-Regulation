        <rdfs:label xml:lang="en">trans-acting post-transcriptional regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000206 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000206">

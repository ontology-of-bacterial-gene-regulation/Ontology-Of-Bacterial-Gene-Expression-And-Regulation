            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000119>A biological macromolecule minimally consisting of one polypeptide chain synthesized at the ribosome.</obo:IAO_0000119>
        <rdfs:isDefinedBy>CHEBI</rdfs:isDefinedBy>

                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000171"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000196"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>a trans-acting regulator that modulates the translation of a messenger RNA into a polypeptide chain</obo:IAO_0000115>
        <rdfs:label xml:lang="en">trans-acting regulator of translation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000083 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000083">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000080"/>
        <obo:IAO_0000115>a trans-acting regulator that modulates the transcription of a DNA segment into an RNA molecule</obo:IAO_0000115>
        <rdfs:label xml:lang="en">trans-acting transcriptional regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000084 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000084">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000083"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000038"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000050"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a trans-acting regulator of transcription that regulates the recognition of the promoter by the RNA polymerase holoenzyme and the formation of the open complex</obo:IAO_0000115>
        <rdfs:comment>Although this definition states that the precise point of regulation is transcription initiation, evidence of regulatory activity may come from observations of increased or decreased levels of the gene product. Therefore, the regulated entity in the formal definition is not limited to the promoter but is generalized to a nucleotide segment.</rdfs:comment>
        <rdfs:label xml:lang="en">trans-acting regulator of transcription initiation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000085 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000085">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000091"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000004"/>
                    </owl:Restriction>
                    <owl:Restriction>

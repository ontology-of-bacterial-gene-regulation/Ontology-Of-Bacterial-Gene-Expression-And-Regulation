        </owl:equivalentClass>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000221"/>
        <obo:IAO_0000115>a DNA-binding regulatory protein of transcription initiation that confers core RNAP promoter specificity, opens duplex DNA and facilitates template strand entry into the RNAP active site</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32665585</obo:IAO_0000119>
        <rdfs:comment>se clasifica como subclase de RNA polymerase holoenzyme!!!!</rdfs:comment>
        <rdfs:label xml:lang="en">sigma factor</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000087 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000087">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000084"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002436"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000008"/>
                            </owl:Restriction>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002436"/>
                                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000221"/>
                            </owl:Restriction>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>a regulator of transcription initiation that regulates transcription initiation by interacting with the RNA polymerase holoenzyme in a specifc subset of promoters</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32665585</obo:IAO_0000119>
        <rdfs:label xml:lang="en">RNAP-centered regulator of transcription initiation</rdfs:label>
    </owl:Class>
    



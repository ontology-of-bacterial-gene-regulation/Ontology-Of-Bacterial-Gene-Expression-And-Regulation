                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000094"/>
        <obo:IAO_0000115>A DNA segment delimited by different nonspurious TSS–TTS pairs.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: ﻿32665585</obo:IAO_0000119>
        <obo:OBAGER_0000033>TU</obo:OBAGER_0000033>
        <rdfs:comment>Transcription units (TUs) are delimited by exactly one promoter–terminator pair. Promoters can produce more than one transcription start site (TSS), and terminators can generate more than one transcription termination site (TTS). Only when alternative TSSs or TTSs are known to have a function or to arise from alternative regulation are two DNA transcribed segments produced by the same promoter–terminator pair, differing only by microvariation at their ends, regarded as distinct TUs.</rdfs:comment>
        <rdfs:label xml:lang="en">transcription unit</rdfs:label>
    </owl:Class>
    



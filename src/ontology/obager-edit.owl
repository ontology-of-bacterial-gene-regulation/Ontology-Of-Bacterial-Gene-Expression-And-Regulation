    <!-- http://purl.obolibrary.org/obo/OBAGER_0000107 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000107">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000058"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000214"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An RNA molecule that is part of the ribosome.</obo:IAO_0000115>
        <obo:OBAGER_0000033>rRNA</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">ribosomal RNA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000108 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000108">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000098"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000046"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000013"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A short RNA molecule, 100-200 nt long.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32213244</obo:IAO_0000119>
        <obo:OBAGER_0000033>sRNA</obo:OBAGER_0000033>
        <rdfs:comment>Some sRNAs are carried in the genome as transcription units that produce only sRNAs, whereas others are transcribed as part of an mRNA and are produced by cleavage in a process called maturation.</rdfs:comment>
        <rdfs:comment>Some sRNAs require a protein cofactor to function. Currently RegulonDB includes sRNAs whose cofactors are RNA-binding protein Hfq, ATP-dependent RNA helicase DeaD or ribonuclease E.</rdfs:comment>
        <rdfs:comment>sRNAs are not necessarily non-coding. Some sRNA are also mRNA, for example, SgrS encodes the 38 amino acid protein SgrT.</rdfs:comment>
        <rdfs:comment>sRNAs regulate gene expression through different mechanisms. Currently in RegulonDB, there are sRNAs that act by translation-blocking and mRNA degradation.</rdfs:comment>
        <rdfs:label xml:lang="en">small RNA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000109 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000109">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000099"/>
        <obo:IAO_0000115>A DNA molecule that naturally occurs in cells.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">chromosome</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000110 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000110">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000098"/>
        <obo:IAO_0000115>An RNA molecule that has been processed by one or more RNases to become a functional molecule.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: 16452296</obo:IAO_0000119>
        <obo:OBAGER_0000033>mature RNA</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">mature transcript</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000115 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000115">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000073"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000074"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000094"/>
        <obo:IAO_0000115>an operon whose transcription is coordinated from a single transcription unit</obo:IAO_0000115>
        <rdfs:label xml:lang="en">simple operon</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000116 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000116">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000073"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000074"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000094"/>
        <obo:IAO_0000115>an operon whose transcription is coordinated through several mutually overlapping transcription units that are transcribed in the same direction and share at least one gene</obo:IAO_0000115>
        <rdfs:label xml:lang="en">complex operon</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000117 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000117">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000135"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000077"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002351"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000215"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000188"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000066"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000077"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A regulon is a set of units of expression that may be scattered throughout the genome, and whose expression is co-regulated by the same diffusible regulatory factor (trans-acting regulator or small molecular regulator). This regulation occurs through a unitary mechanistic process involving specificity, either via direct binding of the regulator to a nucleotide segment or through direct modulation of the binding affinity of RNA polymerase or the ribosome to such segments.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">regulon</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000118 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000118">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000152"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000125"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000002"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000211"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000062"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An heterotypic complex of nucleotide segments near the end of the transcription unit (or transcript) that determines the location of transcript termination, although this might not be a single site.</obo:IAO_0000115>
        <rdfs:comment>In RegulonDB, terminator sequences are represented as DNA sequences. Thus, when a terminator corresponds to an RNA sequence, its template DNA is stored in the database.</rdfs:comment>
        <rdfs:label xml:lang="en">terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000119 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000119">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000118"/>
        <obo:IAO_0000119>PMID: ﻿30978344</obo:IAO_0000119>
        <rdfs:comment>DNA and nascent RNA segments that carry an RNA hairpin and a uridine-rich segment that cause termination without the need for any protein factor.</rdfs:comment>
        <rdfs:label xml:lang="en">intrinsic terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000120 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000120">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000118"/>
        <obo:IAO_0000115>﻿Sites of dissociation of transcription complexes mediated by an RNA helicase called Rho.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: 21439297</obo:IAO_0000119>
        <rdfs:label xml:lang="en">Rho-dependent terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000127 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000127">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000052"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000170"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000129"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000092"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000077"/>
        <obo:IAO_0000119>a continuant that produces a change in a molecular entity and modifies its activity and/or specificity</obo:IAO_0000119>
        <rdfs:label xml:lang="en">effector</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000140"/>
        <obo:IAO_0000115>The arrangement of the side groups on a molecule which can freely rotate into different positions without breaking any bonds.</obo:IAO_0000115>
        <obo:IAO_0000119>Adapted from NCIT</obo:IAO_0000119>
        <rdfs:label xml:lang="en">conformation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000130 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000130">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000117"/>
        <obo:IAO_0000115>a regulon defined by considering one regulator</obo:IAO_0000115>
        <rdfs:label xml:lang="en">simple regulon</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000131 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000131">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000117"/>
        <obo:IAO_0000115>a regulon defined by considering the units of expression regulated by a specified set of regulators</obo:IAO_0000115>
        <rdfs:label xml:lang="en">complex regulon</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000137 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000137">
        <obo:IAO_0000115>A quality of matter and its interactions.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">physico-chemical property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000138 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000138">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000128"/>
        <obo:IAO_0000115>The conformation of a molecular entity in a ligand-unbound state.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: 20066034</obo:IAO_0000119>
        <rdfs:label xml:lang="en">apo conformation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000139 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000139">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000128"/>
        <obo:IAO_0000115>The conformation of a molecular entity in a ligand-bound state.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: 20066034</obo:IAO_0000119>
        <rdfs:label xml:lang="en">holo conformation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000140 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000140">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000137"/>
        <obo:IAO_0000119>A physico-chemical property of a molecule or part of a molecule.</obo:IAO_0000119>
        <rdfs:label xml:lang="en">molecular property</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000141 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000141">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000137"/>
        <obo:IAO_0000119>A physcochemical property that describes how distinct molecules interact.</obo:IAO_0000119>
        <rdfs:label xml:lang="en">property of chemical interaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000142 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000142">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000141"/>
        <obo:IAO_0000119>A property of chemical interaction that describes the fact that the site of ligand binding is different than the active site of an enzyme or the nucleotide binding site of a gene expression regulator.</obo:IAO_0000119>
        <rdfs:label xml:lang="en">allosteric interaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000143 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000143">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000145"/>
        <obo:IAO_0000119>A chemical bond that consists of the simultaneous attraction of two nuclei for one or more pairs of electrons.</obo:IAO_0000119>
        <obo:IAO_0000119>https://www.sciencedirect.com/topics/chemistry/covalent-bond</obo:IAO_0000119>
        <rdfs:label xml:lang="en">covalent bond</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000144 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000144">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000145"/>
        <obo:IAO_0000119>A chemical bond in which no sharing of electrons takes place.</obo:IAO_0000119>
        <obo:OBAGER_0000033>non-covalent interaction</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">non-covalent bond</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000145 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000145">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000141"/>
        <obo:IAO_0000119>A property of chemical interactions that describes how different atoms or ions attract each other and form a stable molecular entity.</obo:IAO_0000119>
        <rdfs:label xml:lang="en">chemical bond</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000146 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000146">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000144"/>
        <obo:IAO_0000115>attractive or repulsive non covalent interaction between objects having electric charges</obo:IAO_0000115>
        <obo:IAO_0000119>http://www.chem.ucla.edu/~harding/IGOC/E/electrostatic_interaction.html</obo:IAO_0000119>
        <rdfs:label xml:lang="en">electrostatic interaction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000147 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000147">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000127"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000176"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>an effector that is a material entity</obo:IAO_0000115>
        <rdfs:label xml:lang="en">material effector</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000148 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000148">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000127"/>
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000137"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment>An effector that is a physico-chemical property.</rdfs:comment>
        <rdfs:label xml:lang="en">physical effector</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000152 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000152">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000050"/>
        <obo:IAO_0000115>A complex constituted by segments of DNA and segments of RNA.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">heterotypic complex of nucleotide segments</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000153 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000153">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000119"/>
        <obo:IAO_0000115>An intrinsic terminator composed of a GC-rich hairpin and a 7–8 nt U-rich tract.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">canonical intrinsic terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000154 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000154">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000097"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000075"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000214"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000075"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000107"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A heterotypic complex biomacromolecular entity formed by RNA molecules and proteins, in which protein synthesis takes place.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">ribosome</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000155 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000155">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000176"/>
        <obo:IAO_0000115>A complex of two or more molecular entities that are not covalently bound.</obo:IAO_0000115>
        <obo:IAO_0000119>COB_0000080</obo:IAO_0000119>
        <rdfs:label xml:lang="en">complex of molecular entities</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000157 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000157">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000167"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000150"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000141"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000169"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000139"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a complex of molecular entities formed by a transcription factor and a molecular effector</obo:IAO_0000115>
        <rdfs:comment>Here we intend to include both  non-covalently and covalently bound  ligands, so methylated and phosphorylated forms can be included. The interaction property &quot;covalent&quot; or &quot;non-covalent&quot; should be added to specific instances of the class.</rdfs:comment>
        <rdfs:comment>When the issue of the ligand superproperties in RO is resolved, maybe It is better to use &apos;has ligand&apos; to link this class to the effector class.</rdfs:comment>
        <rdfs:label xml:lang="en">TF bound to ligand</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000158 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000158">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000170"/>
        <obo:IAO_0000115>an alternative state of molecular entity characterized by molecular configurations or modifications that affect a macromolecular regulator&apos;s activity, stability, or interactions, thereby affecting its regulatory activity on gene expression</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biomacromolecular regulator structural state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000160 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000160">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000167"/>
        <obo:IAO_0000115>a TF alternative state that results of the modification of the TF by a physical effector sucha as light or termperature</obo:IAO_0000115>
        <rdfs:label xml:lang="en">TF modified by physical effector</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000161 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000161">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000167"/>
        <obo:IAO_0000115>a TF alternative state that is a consequence of proteolysis of the TF</obo:IAO_0000115>
        <rdfs:label xml:lang="en">lysed TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000162 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000162">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000167"/>
        <obo:IAO_0000115>a structural state in which a TF is physically bound by another protein, preventing it from accessing its DNA binding site</obo:IAO_0000115>
        <rdfs:label xml:lang="en">TF sequestered by protein</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000163 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000163">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000167"/>
        <obo:IAO_0000115>a TF structural state in which it has formed a multimer with one or more units of protein</obo:IAO_0000115>
        <rdfs:label xml:lang="en">multimeric TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000164 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000164">
        <obo:IAO_0000115>something disassociated from any specific instance</obo:IAO_0000115>
        <obo:IAO_0000119>adapted from https://www.merriam-webster.com/dictionary/abstraction</obo:IAO_0000119>
        <obo:OBAGER_0000033>generically dependent continuant</obo:OBAGER_0000033>
        <rdfs:comment>Although the class Abstraction so far has a single subclass, it was created to make clear that motifs are not molecular entities, nor processes or qualities.</rdfs:comment>
        <rdfs:label xml:lang="en">abstraction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000165 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000165">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000238"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000034"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000229"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000129"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000001"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000238"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000034"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000229"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000134"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000185"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000238"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000034"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000229"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000173"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000002"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <obo:IAO_0000115>A regulatory molecular complex formed by a transcription factor, a DNA fragment, and, optionally, a molecular effector, depending on the functional conformation of the complex.</obo:IAO_0000115>
        <rdfs:comment>The complex of the TF with the TFRS directly regulates promoter activity and thereby controls the expression of transcription units (TUs) and genes. This is reflected in three &apos;regulatory&apos; axioms, which represent that experimental evidence can capture the regulatory effects of this entity at different levels of the expression process.</rdfs:comment>
        <rdfs:label xml:lang="en">TF bound to TFRS</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000166 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000166">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000229"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000169"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000138"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a structural state in which the TF has not undergone post-translational modifications that alter its regulatory capacity</obo:IAO_0000115>
        <rdfs:label xml:lang="en">unmodified TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000167 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000167">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000229"/>
        <obo:IAO_0000115>the state of a TF after being modified by an effector</obo:IAO_0000115>
        <rdfs:label xml:lang="en">modified TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000168 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000168">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000165"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000157"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a TF bound to TFRS whose TF has its activity regulated by a molecular effector</obo:IAO_0000115>
        <rdfs:comment>This class has a functional conformation (holo or apo) associated as opossed to the TF whose activity is regulated by physical effectors for which we cannot associate such property, since the conformational change is not due to a ligand interacting with the TF.</rdfs:comment>
        <rdfs:comment>When there is a molecular effector, the functional conformation is a property of the TF bound to the TFRS, since alternative conformations of the same TF can act on diferent sites.</rdfs:comment>
        <rdfs:label xml:lang="en">TF with molecular effector bound to TFRS</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000170 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000170">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000176"/>
        <obo:IAO_0000115>A specific condition or configuration of a physical entity or object at a particular moment in time. It is a way of describing the attributes, properties, and characteristics of a physical object at a given instant.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">alternative state of molecular entity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000176 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000176">
        <rdfs:isDefinedBy>BFO</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en">material entity</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000177 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000177">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000178"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:allValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000178"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000178"/>
        <obo:IAO_0000115>A gene product produced by the union of more than one simple gene product.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">complex gene product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000178 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000178">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000097"/>
        <obo:IAO_0000115>A biomacromolecule that is produced by transcription or translation of a gene and that has a function other than carrying information, or by the union of such biomacromolecules.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">gene product</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000179 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000179">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000002"/>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:complementOf>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002524"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000185"/>
                    </owl:Restriction>
                </owl:complementOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">transcription unit without genes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000181 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000181">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000119"/>
        <obo:IAO_0000115>An intrinsic terminator whose structure differs from the canonical intrinsic terminator and that difference makes non-canonical terminators weak.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">non-canonical intrinsic terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000182 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000182">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000118"/>
        <obo:IAO_0000115>Sites of dissociation of transcription complexes mediated by a non-canonical intrinsic terminator and the RNA helicase Rho.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">hybrid terminator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000183 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000183">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000049"/>
        <obo:IAO_0000115>The last ribonucleotide incorporated into the transcript before termination.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">last templated base in RNA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000184 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000184">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000049"/>
        <obo:IAO_0000115>The first ribonucleotide in the RNA molecule resulting from transcription.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">first templated base in RNA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000185 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000185">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000045"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000175"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000011"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a DNA continuous segment that carries the information for the structure of at least one functional RNA or polypeptide chain, or a non-functional copy of a parent gene (pseudogene).</obo:IAO_0000115>
        <rdfs:label xml:lang="en">bacterial gene</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000186 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000186">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000185"/>
        <obo:IAO_0000115>﻿DNA sequences that resemble genes but have been mutated into defective forms over the course of evolution</obo:IAO_0000115>
        <obo:IAO_0000119>PMID: ﻿35489061</obo:IAO_0000119>
        <rdfs:comment>Pseudogenes may or may not be transcribed; consequently, not all of them are necessarily part of functional transcription units. Pseudogenes resulting from insertion sequences are continuous DNA sequences that contain two or more non-overlapping CDSs.</rdfs:comment>
        <rdfs:label xml:lang="en">pseudogene</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000187 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000187">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000193"/>
        <obo:IAO_0000115>A macromolecular regulator functional disposition that is realized independently of any effector binding or covalent modification. In this case, the regulator’s ability to bind its target DNA and modulate transcription is governed solely by its expression level, such that the disposition is constitutively realizable whenever the regulator is present.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">constitutively active biomacromolecular regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000188 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000188">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000176"/>
        <obo:IAO_0000115>A material entity that consists of two or more molecular entities that are grouped together based on spatial, functional, or contextual association, without being covalently bonded nor immediately adjacent in the genome nor forming a single chemical structure.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">collection of molecular entities</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000189 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000189">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000163"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000190"/>
        <obo:IAO_0000115>the TF structural state in which it has formed a multimer with units of different proteins</obo:IAO_0000115>
        <rdfs:label xml:lang="en">heterotypic multimeric TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000190 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000190">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000163"/>
        <obo:IAO_0000115>the TF alternative regulatory state in which it has formed a multimer with other units of the same protein</obo:IAO_0000115>
        <rdfs:label xml:lang="en">homotypic multimeric TF</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000191 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000191">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000195"/>
        <obo:IAO_0000115>A conditionally active macromolecular regulator functional disposition that is currently realized; that is, the TF is in a molecular state that enables it to bind its target nucleotide site and modulate transcription or translation.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biomacromolecular regulator active state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000192 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000192">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000195"/>
        <obo:IAO_0000115>A conditionally active macromolecular regulator functional disposition that is currently not realized due to the absence of necessary enabling conditions, such as lack of effector binding, absence of covalent modification, or sequestration by another molecule.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biomacromolecular regulator inactive state</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000193 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000193">
        <obo:IAO_0000115>A realizable property that inheres in a macromolecular regulator, TF or small RNA, by means of which the macromolecular regulator is capable of regulating gene expression under appropriate conditions. The realization of this disposition occurs when the regulator binds its target nucleotide site and modulates transcription or translation.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">biomacromolecular regulator functional disposition</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000195 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000195">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000193"/>
        <obo:IAO_0000115>A macromolecular regulator functional disposition that is realized only under specific conditions, such as the binding of an effector molecule, a covalent modification, or the presence of particular environmental signals. The disposition enables the regulator to control gene expression by binding to its nucleotide site target and modulating transcription or translation, but this realization is contingent on context-dependent molecular or environmental triggers.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">conditionally active biomacromolecular regulator</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000196 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000196">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002516"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000047"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002518"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000069"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000041"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000055"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000049"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000041"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000055"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An RNA segment that begins with start codon and ends with a stop codon.</obo:IAO_0000115>
        <obo:OBAGER_0000033>CDS</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">coding sequence</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000197 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000197">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the σ⁴ domain of σ factors other than σ⁵⁴. It is typically located around 35 base pairs upstream of the transcription start site (TSS, +1).</obo:IAO_0000115>
        <obo:OBAGER_0000033>-35 promoter element</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">-35 promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000198 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000198">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the σ² domain of σ factors other than σ⁵⁴. It is typically located around 10 base pairs upstream of the TSS (+1).</obo:IAO_0000115>
        <obo:OBAGER_0000033>-10 promoter element</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">-10 promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000199 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000199">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the σ³ domain of σ factors other than σ⁵⁴. It plays a compensatory role in promoters with weak or absent -35 or -10 elements.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">extended -10 promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000200 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000200">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by σ54 factor. It is located around -12 base pairs upstream the TSS (+1).</obo:IAO_0000115>
        <obo:OBAGER_0000033>-12 consensus promoter sequence</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">-12 promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000201 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000201">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the σ⁵⁴ factor, typically located around 24 base pairs upstream of the TSS (+1).</obo:IAO_0000115>
        <obo:OBAGER_0000033 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">-24 promoter consensus sequence</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">-24 promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000202 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000202">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the core RNA polymerase enzyme, located on the template strand between positions -4 and +2 relative to the TSS (+1).</obo:IAO_0000115>
        <obo:OBAGER_0000033>CRE</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">core recognition element</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000203 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000203">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the α subunits of RNA polymerase. It typically consists of two subsites located upstream of the -35 element.</obo:IAO_0000115>
        <obo:OBAGER_0000033>UP element</obo:OBAGER_0000033>
        <rdfs:label xml:lang="en">upstream promoter motif</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000204 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000204">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000051"/>
        <obo:IAO_0000115>A promoter motif recognized by the σ² domain, specifically by region σ1.2, of σ factors other than σ⁵⁴.</obo:IAO_0000115>
        <rdfs:comment>This is an element frequently found in promoters that regulate the response to amino acid starvation.</rdfs:comment>
        <rdfs:label xml:lang="en">discriminator element</rdfs:label>
    </owl:Class>
    



                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000050"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000084"/>
        <obo:IAO_0000115>A trans-acting regulator of transcription initiation whose regulatory specificity is determined by the DNA sequence it recognizes.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32665585</obo:IAO_0000119>
        <rdfs:label xml:lang="en">DNA-binding regulator of transcription initiation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000086 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000086">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000075"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000091"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000001"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000173"/>

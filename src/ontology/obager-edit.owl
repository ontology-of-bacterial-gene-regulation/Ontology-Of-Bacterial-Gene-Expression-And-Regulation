        <rdfs:label xml:lang="en">mRNA without Shine-Dalgarno sequence</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OBAGER_0000106 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBAGER_0000106">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000058"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000214"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OBAGER_0000196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:OBAGER_0000033>An RNA molecule that binds an amino acid to its 3′ end and, by means of its anticodon region, brings it to the complementary codon in the mRNA being translated by the ribosome.</obo:OBAGER_0000033>
